<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Task Logs · LINE Gateway</title>
<style>
  :root {
    --bg: #1a1612;
    --bg-elevated: #221d18;
    --bg-card: #2a2420;
    --border: #3a322c;
    --border-strong: #4a4038;
    --text: #e8e0d4;
    --text-muted: #9a9088;
    --text-dim: #6a6058;
    --accent: #c9a961;
    --accent-soft: #c9a96133;
    --green: #8fbc6c;
    --amber: #d4a04c;
    --red: #c97a6b;
    --blue: #7ba3c4;
    --mono: "JetBrains Mono", "SF Mono", "Cascadia Code", "Consolas", monospace;
    --serif: "Noto Serif TC", "Source Han Serif TC", "PingFang TC", serif;
    --sans: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    line-height: 1.7;
    min-height: 100vh;
    padding: 48px 24px;
    background-image:
      radial-gradient(circle at 20% 0%, #2a201833 0%, transparent 50%),
      radial-gradient(circle at 80% 100%, #1f2a2233 0%, transparent 50%);
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  /* ===== HEADER ===== */
  .hero {
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .hero h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 56px;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--text-muted);
  }

  /* ===== STATS ===== */
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 20px;
    margin-bottom: 56px;
  }

  .stat {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 4px;
  }

  .stat-value {
    font-family: var(--serif);
    font-size: 36px;
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  /* ===== FILTER ===== */
  .filter-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .filter-chip {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.05em;
    padding: 6px 14px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    color: var(--text-muted);
    background: transparent;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .filter-chip:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .filter-chip.active {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  /* ===== LOG LIST ===== */
  .timeline {
    position: relative;
    padding-left: 32px;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 6px;
    top: 12px;
    bottom: 12px;
    width: 1px;
    background: linear-gradient(180deg,
      var(--accent) 0%,
      var(--border) 30%,
      var(--border) 70%,
      transparent 100%);
  }

  .log-entry {
    position: relative;
    margin-bottom: 32px;
    padding: 0;
  }

  .log-entry::before {
    content: "";
    position: absolute;
    left: -32px;
    top: 24px;
    width: 13px;
    height: 13px;
    background: var(--bg);
    border: 2px solid var(--accent);
    border-radius: 50%;
    transform: rotate(45deg);
  }

  .log-entry a.log-link {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 24px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .log-entry a.log-link:hover {
    border-color: var(--accent);
    transform: translateX(4px);
    background: var(--bg-card);
  }

  .log-date {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .log-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .log-summary {
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 12px;
  }

  .log-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .log-tag {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    padding: 3px 8px;
    border: 1px solid var(--border-strong);
    border-radius: 2px;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .log-tag.stage { color: var(--accent); border-color: var(--accent); }
  .log-tag.line { color: var(--green); border-color: #2d4a24; }
  .log-tag.webapp { color: var(--blue); border-color: #244a4a; }
  .log-tag.fix { color: var(--amber); border-color: #4a3a24; }

  /* empty state */
  .empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-dim);
    font-family: var(--serif);
    font-style: italic;
  }

  /* footer */
  .footer {
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  @media (max-width: 640px) {
    body { padding: 24px 16px; }
    .hero h1 { font-size: 36px; }
  }
</style>
</head>
<body>
<div class="container">

  <header class="hero">
    <div class="hero-eyebrow">LINE Gateway · Task Logs</div>
    <h1>工程紀錄</h1>
    <div class="hero-sub">每一次 Claude Code 的足跡，都是一塊磚</div>
  </header>

  <!-- ====== STATS（手動更新 or 之後自動算）====== -->
  <div class="stats">
    <div class="stat">
      <div class="stat-value">{{TOTAL_LOGS}}</div>
      <div class="stat-label">Total Logs</div>
    </div>
    <div class="stat">
      <div class="stat-value">{{CURRENT_STAGE}}</div>
      <div class="stat-label">Current Stage</div>
    </div>
    <div class="stat">
      <div class="stat-value">{{LAST_UPDATE}}</div>
      <div class="stat-label">Last Update</div>
    </div>
  </div>

  <!-- ====== FILTER（純視覺、可選做成 JS）====== -->
  <div class="filter-row">
    <button class="filter-chip active" data-filter="all">All</button>
    <button class="filter-chip" data-filter="stage-pre4">Pre-Stage4</button>
    <button class="filter-chip" data-filter="stage-4">Stage 4</button>
    <button class="filter-chip" data-filter="line">LINE</button>
    <button class="filter-chip" data-filter="webapp">Web App</button>
    <button class="filter-chip" data-filter="fix">Fix</button>
  </div>

  <!-- ====== TIMELINE ====== -->
  <div class="timeline">

    <!-- ============================================================
         範例 log entry（複製貼上修改即可）
         data-tags：用空格分隔，對應上面 filter 的 data-filter
         ============================================================ -->

    <!--
    <article class="log-entry" data-tags="stage-pre4 line">
      <a class="log-link" href="./2026-05-26_setup_rich_menu.html">
        <div class="log-date">2026-05-26 · 14:30</div>
        <h2 class="log-title">Setup Rich Menu</h2>
        <p class="log-summary">
          建立 LINE Rich Menu 四格招牌（關於我們 / 拜拜通 / 最新消息 / 合作管道），
          全部 deep link 跳 Web App。
        </p>
        <div class="log-tags">
          <span class="log-tag stage">Pre-Stage4</span>
          <span class="log-tag line">LINE</span>
        </div>
      </a>
    </article>
    -->

    {{LOG_ENTRIES}}

  </div>

  <footer class="footer">
    LINE Gateway · Max · 2026
  </footer>

</div>

<script>
  // 簡單 filter 功能
  const chips = document.querySelectorAll('.filter-chip');
  const entries = document.querySelectorAll('.log-entry');

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      const filter = chip.dataset.filter;
      entries.forEach(entry => {
        const tags = (entry.dataset.tags || '').split(' ');
        entry.style.display = (filter === 'all' || tags.includes(filter)) ? '' : 'none';
      });
    });
  });
</script>

</body>
</html>
