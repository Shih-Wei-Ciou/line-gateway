<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{TASK_TITLE}} · Task Log</title>
<style>
  :root {
    --bg: #1a1612;
    --bg-elevated: #221d18;
    --bg-card: #2a2420;
    --border: #3a322c;
    --border-strong: #4a4038;
    --text: #e8e0d4;
    --text-muted: #9a9088;
    --text-dim: #6a6058;
    --accent: #c9a961;
    --accent-soft: #c9a96133;
    --green: #8fbc6c;
    --amber: #d4a04c;
    --red: #c97a6b;
    --blue: #7ba3c4;
    --mono: "JetBrains Mono", "SF Mono", "Cascadia Code", "Consolas", monospace;
    --serif: "Noto Serif TC", "Source Han Serif TC", "PingFang TC", serif;
    --sans: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    line-height: 1.7;
    min-height: 100vh;
    padding: 48px 24px;
    background-image:
      radial-gradient(circle at 20% 0%, #2a201833 0%, transparent 50%),
      radial-gradient(circle at 80% 100%, #1f2a2233 0%, transparent 50%);
  }

  .container {
    max-width: 880px;
    margin: 0 auto;
  }

  /* ===== HEADER ===== */
  .header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 32px;
    margin-bottom: 48px;
  }

  .header-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 4px 10px;
    border: 1px solid var(--accent);
    border-radius: 2px;
    margin-bottom: 16px;
  }

  .header h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 38px;
    line-height: 1.25;
    margin-bottom: 20px;
    color: var(--text);
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .meta-item {
    border-left: 2px solid var(--accent);
    padding-left: 12px;
  }

  .meta-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 4px;
  }

  .meta-value {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--text);
  }

  /* ===== SECTION ===== */
  section {
    margin-bottom: 48px;
  }

  .section-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-title::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  .section-title .glyph {
    font-size: 18px;
    color: var(--accent);
  }

  /* ===== BLOCKS ===== */
  .prose {
    color: var(--text-muted);
    font-size: 15px;
  }

  .prose p + p { margin-top: 12px; }

  /* file diff */
  .file-list {
    list-style: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .file-list li {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    font-family: var(--mono);
    font-size: 13px;
    background: var(--bg-elevated);
  }

  .file-list li:last-child { border-bottom: none; }

  .file-badge {
    flex-shrink: 0;
    font-size: 10px;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    border-radius: 2px;
    margin-right: 14px;
    min-width: 62px;
    text-align: center;
  }

  .file-badge.new {
    background: #2d4a2433;
    color: var(--green);
    border: 1px solid #2d4a24;
  }

  .file-badge.modified {
    background: #4a3a2433;
    color: var(--amber);
    border: 1px solid #4a3a24;
  }

  .file-badge.deleted {
    background: #4a242433;
    color: var(--red);
    border: 1px solid #4a2424;
  }

  .file-path {
    color: var(--text);
    flex: 1;
  }

  .file-note {
    color: var(--text-dim);
    font-size: 12px;
    margin-left: 12px;
  }

  /* checklist */
  .checklist {
    list-style: none;
  }

  .checklist li {
    padding: 10px 0;
    padding-left: 32px;
    position: relative;
    color: var(--text-muted);
    border-bottom: 1px dashed var(--border);
  }

  .checklist li:last-child { border-bottom: none; }

  .checklist li::before {
    content: "☐";
    position: absolute;
    left: 0;
    top: 8px;
    font-size: 16px;
    color: var(--text-dim);
    font-family: var(--mono);
  }

  .checklist li.done::before {
    content: "☑";
    color: var(--green);
  }

  .checklist li.done {
    color: var(--text-dim);
    text-decoration: line-through;
  }

  /* decision / note cards */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    padding: 16px 20px;
    border-radius: 2px;
    margin-bottom: 12px;
  }

  .card.warn { border-left-color: var(--amber); }
  .card.info { border-left-color: var(--blue); }
  .card.danger { border-left-color: var(--red); }

  .card-title {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .card.warn .card-title { color: var(--amber); }
  .card.info .card-title { color: var(--blue); }
  .card.danger .card-title { color: var(--red); }

  .card-body {
    font-size: 14px;
    color: var(--text);
  }

  /* code block */
  pre {
    background: #0f0c0a;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px 20px;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.6;
    color: var(--text);
    margin: 12px 0;
  }

  code {
    font-family: var(--mono);
    font-size: 0.92em;
    background: var(--bg-elevated);
    padding: 2px 6px;
    border-radius: 2px;
    color: var(--accent);
  }

  pre code {
    background: none;
    padding: 0;
    color: var(--text);
  }

  /* next step */
  .next-step {
    background: linear-gradient(135deg, var(--accent-soft) 0%, transparent 100%);
    border: 1px solid var(--accent);
    padding: 24px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .next-step-arrow {
    font-family: var(--serif);
    font-size: 36px;
    color: var(--accent);
    line-height: 1;
  }

  .next-step-content {
    flex: 1;
  }

  .next-step-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .next-step-text {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--text);
  }

  /* footer */
  .footer {
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .footer a {
    color: var(--accent);
    text-decoration: none;
  }

  /* responsive */
  @media (max-width: 640px) {
    body { padding: 24px 16px; }
    .header h1 { font-size: 28px; }
    .next-step { flex-direction: column; text-align: center; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- ====== HEADER ====== -->
  <header class="header">
    <div class="header-tag">{{STAGE_TAG}}</div>
    <h1>{{TASK_TITLE}}</h1>
    <div class="meta-grid">
      <div class="meta-item">
        <div class="meta-label">Date</div>
        <div class="meta-value">{{DATE}}</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Duration</div>
        <div class="meta-value">{{DURATION}}</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Tool</div>
        <div class="meta-value">Claude Code</div>
      </div>
      <div class="meta-item">
        <div class="meta-label">Status</div>
        <div class="meta-value" style="color: var(--green);">● Completed</div>
      </div>
    </div>
  </header>

  <!-- ====== 任務目標 ====== -->
  <section>
    <h2 class="section-title">任務目標</h2>
    <div class="prose">
      <p>{{TASK_GOAL}}</p>
    </div>
  </section>

  <!-- ====== 檔案變動 ====== -->
  <section>
    <h2 class="section-title">檔案變動</h2>
    <ul class="file-list">
      <!-- 範例：
      <li>
        <span class="file-badge new">NEW</span>
        <span class="file-path">scripts/setup_rich_menu.py</span>
        <span class="file-note">完整腳本</span>
      </li>
      <li>
        <span class="file-badge modified">MODIFIED</span>
        <span class="file-path">.env.example</span>
        <span class="file-note">+1 行 WEBAPP_BASE_URL</span>
      </li>
      -->
      {{FILE_CHANGES}}
    </ul>
  </section>

  <!-- ====== 關鍵實作決策 ====== -->
  <section>
    <h2 class="section-title">關鍵實作決策</h2>
    <!-- 範例：
    <div class="card">
      <div class="card-title">Decision</div>
      <div class="card-body">為什麼這樣做 ...</div>
    </div>
    -->
    {{DECISIONS}}
  </section>

  <!-- ====== 待確認 / 待辦 ====== -->
  <section>
    <h2 class="section-title">待確認 / 待辦</h2>
    <ul class="checklist">
      <!-- 範例：
      <li>URL path 是否正確（/about, /, /news, /partner）</li>
      <li class="done">.env LINE_CHANNEL_ACCESS_TOKEN 確認</li>
      -->
      {{TODO_LIST}}
    </ul>
  </section>

  <!-- ====== 驗收 ====== -->
  <section>
    <h2 class="section-title">驗收 Checklist</h2>
    <ul class="checklist">
      {{VERIFY_LIST}}
    </ul>
  </section>

  <!-- ====== 下一步 ====== -->
  <section>
    <div class="next-step">
      <div class="next-step-arrow">→</div>
      <div class="next-step-content">
        <div class="next-step-label">Next</div>
        <div class="next-step-text">{{NEXT_STEP}}</div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <a href="./index.html">← Back to Index</a>
    &nbsp;·&nbsp;
    LINE Gateway · Task Log
  </footer>

</div>
</body>
</html>
