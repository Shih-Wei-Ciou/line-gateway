# ═══════════════════════════════════════════════════════════
# LINE Gateway — 環境變數範本
# 複製成 .env 後填入真實值，.env 不可進版控（已加入 .gitignore）
# 標記 [必填] 的變數若留空，服務將無法正常啟動
# ═══════════════════════════════════════════════════════════

# ── Flask ───────────────────────────────────────────────────
# [必填] production 請改成 production
FLASK_ENV=development
# [必填] 任意長隨機字串，用於 session 簽名
SECRET_KEY=change-me-to-random-string

# ── PostgreSQL ──────────────────────────────────────────────
# [必填] 格式：postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:dev@localhost:5432/gateway

# ── LINE Messaging API Channel（Bot 用）────────────────────
# [必填] LINE Developers → Messaging API → Channel secret
LINE_CHANNEL_SECRET=
# [必填] LINE Developers → Messaging API → Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=

# ── LINE LIFF（Login Channel 用）───────────────────────────
# [必填] 訂閱頁 LIFF ID，格式：{channelId}-{liffId}
LIFF_ID_SUBSCRIBE=
# 個人資料頁 LIFF ID（Stage 4 以後才用）
LIFF_ID_PROFILE=
# 我的報名頁 LIFF ID（Stage 5 以後才用）
LIFF_ID_MY_REGISTRATIONS=

# ── TEP（廟宇平台）─────────────────────────────────────────
# TEP API base URL，本機開發時指向 TEP local server
TEP_BASE_URL=http://localhost:5000/api
# TEP 給本系統的 API Key（TEP → Gateway 呼叫時帶入）
TEP_API_KEY=

# ── Gateway Internal API ────────────────────────────────────
# 本系統對外暴露的 Internal API 金鑰（TEP 呼叫 /internal/* 時帶入）
# [必填] 任意長隨機字串，與 TEP 端設定值一致
GATEWAY_INTERNAL_KEY=change-me-to-random-string

# ── Web App ─────────────────────────────────────────────────
# Web App base URL (no trailing slash)
WEBAPP_BASE_URL=https://baibaitong-webapp.zeabur.app

# ── Admin / 訊息測試 API ────────────────────────────────────
# [必填] POST /admin/test/send 要帶 X-Admin-Key header 才能呼叫
ADMIN_KEY=change-me-to-random-string
# 測試訊息預設收件人（自己的 LINE UID，Uxxxxxxxxxxx 格式），可在 body 覆寫
ADMIN_LINE_UID=
